<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        False positive: keycloak-oauth2-starter is an internal library that wraps the
        Keycloak client SDK. OWASP matches its JAR name against the Keycloak upstream
        product CPE (cpe:2.3:a:keycloak:keycloak:1.0) and incorrectly flags historic
        Keycloak server vulnerabilities that do not apply to this library.
    -->
    <suppress>
        <notes>Internal keycloak-oauth2-starter adapter — not the Keycloak server product.</notes>
        <gav regex="true">dk\.ufst:keycloak-oauth2-starter:.*</gav>
        <cve>CVE-2014-3651</cve>
    </suppress>
    <suppress>
