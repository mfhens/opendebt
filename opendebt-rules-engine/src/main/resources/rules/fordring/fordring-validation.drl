package dk.ufst.opendebt.rules.fordring

// Fordring (claim action) validation rules
// Implements core validation from petition015
// Extension points for petition016, petition017, petition018

import dk.ufst.opendebt.common.dto.fordring.FordringValidationRequest
import dk.ufst.opendebt.common.dto.fordring.FordringValidationResult
import dk.ufst.opendebt.common.dto.fordring.FordringErrorCode

global FordringValidationResult validationResult

// ============================================================
// Structure Validation Rules (petition015)
// ============================================================

rule "OPRETFORDRING requires MFOpretFordringStruktur"
    agenda-group "fordring-validation"
    when
        $req : FordringValidationRequest(
            aktionKode == "OPRETFORDRING",
            mfOpretFordringStrukturPresent == false
        )
    then
        validationResult.addError(FordringErrorCode.OPRETFORDRING_STRUKTUR, "MFOpretFordringStruktur");
end

rule "GENINDSENDFORDRING requires MFGenindsendFordringStruktur"
    agenda-group "fordring-validation"
    when
        $req : FordringValidationRequest(
            aktionKode == "GENINDSENDFORDRING",
            mfGenindsendFordringStrukturPresent == false
        )
    then
        validationResult.addError(FordringErrorCode.GENINDSEND_STRUCTURE_MISSING, "MFGenindsendFordringStruktur");
end

rule "NEDSKRIV requires MFNedskrivFordringStruktur"
    agenda-group "fordring-validation"
    when
        $req : FordringValidationRequest(
            aktionKode == "NEDSKRIV",
            mfNedskrivFordringStrukturPresent == false
        )
    then
        validationResult.addError(FordringErrorCode.NEDSKRIV_STRUKTUR_MISSING, "MFNedskrivFordringStruktur");
end

rule "TILBAGEKALD requires MFTilbagekaldFordringStruktur"
    agenda-group "fordring-validation"
    when
        $req : FordringValidationRequest(
            aktionKode == "TILBAGEKALD",
