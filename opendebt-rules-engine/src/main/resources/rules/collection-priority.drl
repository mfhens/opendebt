package dk.ufst.opendebt.rules

import dk.ufst.opendebt.rules.model.CollectionPriorityRequest
import dk.ufst.opendebt.rules.model.CollectionPriorityResult
import java.time.LocalDate

global CollectionPriorityResult result

// ============================================================================
// GIL § 4 Daekningsraekkefoeige — Inter-claim priority order
//
// Catala source: ga_2_3_2_1_daekningsraekkefoeigen.catala_da (G.A. v3.16, 2026-03-28)
// Legal basis  : GIL § 4, stk. 1-2; GIL § 6a; GIL § 10b; lov nr. 288/2022
// TB-034       : Fixed wrong category order (was: boernebidrag #1, skat #2, boeder #3)
//                Correct: rimelige_omkostninger (1) -> boeder/tvangsboeder (2)
//                         -> underholdsbidrag (3) -> andre_fordringer (4)
//
// This file governs INTER-claim ordering only. Intra-claim ordering
// (rente -> gebyrer -> hauptfordring) is handled in CoveragePriorityServiceImpl.
//
// NOTE: Drools/MVEL uses JavaBean property names derived from getter conventions.
// For boolean fields named "isXxx" (Lombok generates isXxx()), the MVEL property
// name is "xxx" (stripping the "is" prefix per JavaBeans spec). Example:
//   boolean isFine  ->  Lombok getter: isFine()  ->  MVEL property: fine
// ============================================================================

// ============================================================================
// FIFO Sort Key — GIL § 4, stk. 2 (FR-2.1 / FR-2.2)
//
// FR-2.1: fifoSortKey = oprettetDato (fordringens modtagelsesdato)
// FR-2.2: Exception for claims transferred before 1 September 2013:
//         use legacyOprettetDato as FIFO key instead (GIL § 4, stk. 2, 5. pkt.)
// ============================================================================
rule "GIL4 FIFO Sort Key — FR-2.1 / FR-2.2 (GIL § 4, stk. 2)"
    salience 200
    when
        $req : CollectionPriorityRequest(oprettetDato != null)
    then
        LocalDate fifoKey = $req.getOprettetDato();
        // FR-2.2: pre-2013 legacy date takes precedence (GIL § 4, stk. 2, 5. pkt.)
        // MVEL RHS uses Java getter directly: isHarLegacyOprettetDato()
        if ($req.isHarLegacyOprettetDato()
                && $req.getLegacyOprettetDato() != null
                && $req.getLegacyOprettetDato().isBefore(LocalDate.of(2013, 9, 1))) {
            fifoKey = $req.getLegacyOprettetDato();
        }
        result.setFifoSortKey(fifoKey);
end

// ============================================================================
// Category 1 (rank 1): Rimelige omkostninger
// Catala: RIMELIGE_OMKOSTNINGER -> prioritetRang = 1 (FR-1.1)
// Legal: GIL § 6a, stk. 1; GIL § 6a, stk. 12
// Covered before all other claims.
// MVEL property: rimeligOmkostning  (from boolean isRimeligOmkostning -> getter isRimeligOmkostning())
// ============================================================================
rule "GIL4 Kategori 1 — Rimelige Omkostninger (GIL § 6a)"
    when
        $req : CollectionPriorityRequest(rimeligOmkostning == true)
    then
        result.setPriorityRank(CollectionPriorityResult.GIL4_RIMELIGE_OMKOSTNINGER);
        result.setPriorityCategory("RIMELIGE_OMKOSTNINGER");
        result.setUnderholdsbidragOrdning(0);
        result.setLegalBasis(
            "GIL § 6a, stk. 1; GIL § 6a, stk. 12 — Rimelige omkostninger daekkes forud for alle oevrige fordringer (FR-1.1)");
end

// ============================================================================
// Category 2 (rank 2): Boeder, tvangsboeder og tilbagebetalingskrav
// Catala: BOEDER_TVANGSBOEEDER_TILBAGEBETALING -> prioritetRang = 2 (FR-1.2)
// Legal: GIL § 10b; lov nr. 288/2022 § 2, nr. 1
// AIDEV-NOTE: Previously incorrectly assigned rank 3 — corrected by TB-034.
// MVEL property: fine  (from boolean isFine -> getter isFine())
// ============================================================================
rule "GIL4 Kategori 2 — Boeder, Tvangsboeder og Tilbagebetaling (GIL § 10b)"
    when
        $req : CollectionPriorityRequest(
            fine == true,
            rimeligOmkostning == false
        )
    then
        result.setPriorityRank(CollectionPriorityResult.GIL4_BOEDER_TVANGSBOEEDER_TILBAGEBETALING);
        result.setPriorityCategory(CollectionPriorityResult.CATEGORY_BOEDER_TVANGSBOEEDER_TILBAGEBETALING);
        result.setUnderholdsbidragOrdning(0);
        result.setLegalBasis(
            "GIL § 10b; lov nr. 288/2022 § 2, nr. 1 — Boeder, tvangsboeder og tilbagebetalingskrav er kategori 2 (FR-1.2)");
end

// ============================================================================
// Category 3a (rank 3, ordning 1): Privatretligt underholdsbidrag
// Catala: UNDERHOLDSBIDRAG_PRIVATRETLIG -> prioritetRang = 3, underholdsbidragOrdning = 1 (FR-1.3a/c)
// Legal: GIL § 4, stk. 1, nr. 2
// Covered before offentlig underholdsbidrag within category 3.
// AIDEV-NOTE: Previously incorrectly assigned rank 1 — corrected by TB-034.
// MVEL properties: childSupport, privatUnderholdsbidrag
// ============================================================================
rule "GIL4 Kategori 3a — Underholdsbidrag Privatretlig (GIL § 4, stk. 1, nr. 2)"
    when
        $req : CollectionPriorityRequest(
            childSupport == true,
            privatUnderholdsbidrag == true,
            rimeligOmkostning == false,
            fine == false
        )
    then
        result.setPriorityRank(CollectionPriorityResult.GIL4_UNDERHOLDSBIDRAG);
        result.setPriorityCategory("UNDERHOLDSBIDRAG_PRIVATRETLIG");
        result.setUnderholdsbidragOrdning(1);
        result.setLegalBasis(
            "GIL § 4, stk. 1, nr. 2 — Privatretligt underholdsbidrag daekkes forud for offentligretligt inden for kategori 3 (FR-1.3a/c)");
end

// ============================================================================
// Category 3b (rank 3, ordning 2): Offentligretligt underholdsbidrag
// Catala: UNDERHOLDSBIDRAG_OFFENTLIG -> prioritetRang = 3, underholdsbidragOrdning = 2 (FR-1.3b/d)
// Legal: GIL § 4, stk. 1, nr. 2
// AIDEV-NOTE: Previously incorrectly assigned rank 1 — corrected by TB-034.
// MVEL properties: childSupport, privatUnderholdsbidrag
// ============================================================================
rule "GIL4 Kategori 3b — Underholdsbidrag Offentlig (GIL § 4, stk. 1, nr. 2)"
    when
        $req : CollectionPriorityRequest(
            childSupport == true,
            privatUnderholdsbidrag == false,
            rimeligOmkostning == false,
            fine == false
        )
    then
        result.setPriorityRank(CollectionPriorityResult.GIL4_UNDERHOLDSBIDRAG);
        result.setPriorityCategory("UNDERHOLDSBIDRAG_OFFENTLIG");
        result.setUnderholdsbidragOrdning(2);
        result.setLegalBasis(
            "GIL § 4, stk. 1, nr. 2 — Offentligretligt underholdsbidrag, ordning 2 inden for kategori 3 (FR-1.3b/d)");
end

// ============================================================================
// Category 4 (rank 4): Andre fordringer
// Catala: ANDRE_FORDRINGER -> prioritetRang = 4 (FR-1.4)
// Legal: GIL § 4, stk. 1, nr. 3
// Covers: tax debts, court-ordered debts, and all other claims not in categories 1-3.
// AIDEV-NOTE: Tax debt previously incorrectly assigned rank 2 — corrected by TB-034.
// MVEL properties: rimeligOmkostning, fine, childSupport
// ============================================================================
rule "GIL4 Kategori 4 — Andre Fordringer (GIL § 4, stk. 1, nr. 3)"
    salience -100
    when
        $req : CollectionPriorityRequest(
            rimeligOmkostning == false,
            fine == false,
            childSupport == false
        )
    then
        result.setPriorityRank(CollectionPriorityResult.GIL4_ANDRE_FORDRINGER);
        result.setPriorityCategory("ANDRE_FORDRINGER");
        result.setUnderholdsbidragOrdning(0);
        result.setLegalBasis(
            "GIL § 4, stk. 1, nr. 3 — Andre fordringer daekkes sidst, herunder skattegaeld og retsafgoerelser (FR-1.4)");
end
