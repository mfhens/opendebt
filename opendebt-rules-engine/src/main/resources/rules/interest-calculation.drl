package dk.ufst.opendebt.rules

import dk.ufst.opendebt.rules.model.InterestCalculationRequest
import dk.ufst.opendebt.rules.model.InterestCalculationResult
import java.math.BigDecimal
import java.math.RoundingMode

global InterestCalculationResult result

// ─────────────────────────────────────────────────────────────────────────────
// GUARD RULES  (salience ≥ 90 — fire before any rate rule)
// ─────────────────────────────────────────────────────────────────────────────

// Salience 200 — debt not yet past due date
rule "No Interest Before Due Date"
    salience 200
    no-loop true
    when
        $req : InterestCalculationRequest(daysPastDue <= 0)
    then
        result.setInterestAmount(BigDecimal.ZERO);
        result.setInterestRate(BigDecimal.ZERO);
        result.setRateType("NOT_DUE");
        result.setLegalBasis("Gæld endnu ikke forfalden");
end

// Salience 100 — straffebøder are interest-exempt
// (Gældsinddrivelsesloven § 5, stk. 1; Retsplejeloven § 997, stk. 3)
rule "INDR_EXEMPT: Straffebøder"
    salience 100
    no-loop true
    when
        $req : InterestCalculationRequest(
            daysPastDue > 0,
            interestRule == "INDR_EXEMPT"
        )
    then
        result.setInterestAmount(BigDecimal.ZERO);
        result.setInterestRate(BigDecimal.ZERO);
        result.setRateType("INDR_EXEMPT");
        result.setLegalBasis("Gældsinddrivelsesloven § 5, stk. 1; Retsplejeloven § 997, stk. 3");
end

// Salience 90 — amounts below 100 kr do not accrue interest
rule "No Interest For Small Amounts"
    salience 90
    no-loop true
    when
        $req : InterestCalculationRequest(
            daysPastDue > 0,
            principalAmount != null,
            principalAmount.compareTo(new BigDecimal("100")) < 0
        )
    then
        result.setInterestAmount(BigDecimal.ZERO);
        result.setInterestRate(BigDecimal.ZERO);
        result.setRateType("SMALL_AMOUNT");
        result.setLegalBasis("Beløb under 100 kr — ingen rente");
end

// ─────────────────────────────────────────────────────────────────────────────
// RATE RULES  (salience 50 — mutually exclusive on interestRule)
//
// Formula: interest = principal × (annualRate / 365) × daysPastDue
//
// annualRate is pre-resolved by the caller via:
//   BusinessConfigService.getDecimalValue(configKey, calculationDate)
// The caller MUST use request.calculationDate (not LocalDate.now()) so that
// retroactive recalculations (petition039) use the historically correct rate.
// ─────────────────────────────────────────────────────────────────────────────

// Salience 50 — INDR_STD: Gældsinddrivelsesloven § 5, stk. 1-2
rule "INDR_STD: Standard Rate"
    salience 50
    no-loop true
    when
        $req : InterestCalculationRequest(
            daysPastDue > 0,
            principalAmount != null,
            principalAmount.compareTo(new BigDecimal("100")) >= 0,
            interestRule == "INDR_STD",
            annualRate != null
        )
    then
        BigDecimal dailyRate = $req.getAnnualRate().divide(new BigDecimal("365"), 10, RoundingMode.HALF_UP);
        BigDecimal interest = $req.getPrincipalAmount()
            .multiply(dailyRate)
            .multiply(new BigDecimal($req.getDaysPastDue()))
            .setScale(2, RoundingMode.HALF_UP);
        result.setInterestAmount(interest);
        result.setInterestRate($req.getAnnualRate().multiply(new BigDecimal("100")));
        result.setRateType("INDR_STD");
        result.setLegalBasis("Gældsinddrivelsesloven § 5, stk. 1-2");
end

// Salience 50 — INDR_TOLD: EU-toldkodeks art. 114; Toldloven § 30a (no payment plan)
rule "INDR_TOLD: Told Rate"
    salience 50
    no-loop true
    when
        $req : InterestCalculationRequest(
            daysPastDue > 0,
            principalAmount != null,
            principalAmount.compareTo(new BigDecimal("100")) >= 0,
            interestRule == "INDR_TOLD",
            annualRate != null
        )
    then
        BigDecimal dailyRate = $req.getAnnualRate().divide(new BigDecimal("365"), 10, RoundingMode.HALF_UP);
        BigDecimal interest = $req.getPrincipalAmount()
            .multiply(dailyRate)
            .multiply(new BigDecimal($req.getDaysPastDue()))
            .setScale(2, RoundingMode.HALF_UP);
        result.setInterestAmount(interest);
        result.setInterestRate($req.getAnnualRate().multiply(new BigDecimal("100")));
        result.setRateType("INDR_TOLD");
        result.setLegalBasis("EU-toldkodeks art. 114; Toldloven § 30a");
end

// Salience 50 — INDR_TOLD_AFD: EU-toldkodeks art. 114 (with afdragsordning)
rule "INDR_TOLD_AFD: Told Afdrag Rate"
    salience 50
    no-loop true
    when
        $req : InterestCalculationRequest(
            daysPastDue > 0,
            principalAmount != null,
            principalAmount.compareTo(new BigDecimal("100")) >= 0,
            interestRule == "INDR_TOLD_AFD",
            annualRate != null
        )
    then
        BigDecimal dailyRate = $req.getAnnualRate().divide(new BigDecimal("365"), 10, RoundingMode.HALF_UP);
        BigDecimal interest = $req.getPrincipalAmount()
            .multiply(dailyRate)
            .multiply(new BigDecimal($req.getDaysPastDue()))
            .setScale(2, RoundingMode.HALF_UP);
        result.setInterestAmount(interest);
        result.setInterestRate($req.getAnnualRate().multiply(new BigDecimal("100")));
        result.setRateType("INDR_TOLD_AFD");
        result.setLegalBasis("EU-toldkodeks art. 114 (med afdragsordning)");
end

// Salience 50 — INDR_CONTRACT: contractual rate from fordringshaver
// (Gældsinddrivelsesbekendtgørelsen § 9, stk. 3)
rule "INDR_CONTRACT: Contractual Rate"
    salience 50
    no-loop true
    when
        $req : InterestCalculationRequest(
            daysPastDue > 0,
            principalAmount != null,
            principalAmount.compareTo(new BigDecimal("100")) >= 0,
            interestRule == "INDR_CONTRACT",
            annualRate != null
        )
    then
        BigDecimal dailyRate = $req.getAnnualRate().divide(new BigDecimal("365"), 10, RoundingMode.HALF_UP);
        BigDecimal interest = $req.getPrincipalAmount()
            .multiply(dailyRate)
            .multiply(new BigDecimal($req.getDaysPastDue()))
            .setScale(2, RoundingMode.HALF_UP);
        result.setInterestAmount(interest);
        result.setInterestRate($req.getAnnualRate().multiply(new BigDecimal("100")));
        result.setRateType("INDR_CONTRACT");
        result.setLegalBasis("Gældsinddrivelsesbekendtgørelsen § 9, stk. 3");
end

