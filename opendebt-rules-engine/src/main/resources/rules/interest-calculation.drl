package dk.ufst.opendebt.rules

import dk.ufst.opendebt.rules.model.InterestCalculationRequest
import dk.ufst.opendebt.rules.model.InterestCalculationResult
import java.math.BigDecimal
import java.math.RoundingMode

global InterestCalculationResult result

// Standard public debt interest rate (Nationalbankens udlaansrente + 8%)
rule "Standard Interest Rate"
    when
        $request : InterestCalculationRequest(
            isPublicDebt == true,
            daysPastDue > 0
        )
    then
        // Standard rate: approximately 10% p.a. (simplified)
        BigDecimal annualRate = new BigDecimal("0.10");
        BigDecimal dailyRate = annualRate.divide(new BigDecimal("365"), 10, RoundingMode.HALF_UP);
        BigDecimal principal = $request.getPrincipalAmount();
        BigDecimal days = new BigDecimal($request.getDaysPastDue());
        
        BigDecimal interest = principal.multiply(dailyRate).multiply(days)
            .setScale(2, RoundingMode.HALF_UP);
        
        result.setInterestAmount(interest);
        result.setInterestRate(annualRate.multiply(new BigDecimal("100")));
        result.setRateType("STANDARD_PUBLIC");
        result.setLegalBasis("Renteloven § 5 - Procesrente");
end

// No interest for very small amounts
rule "No Interest For Small Amounts"
    when
        $request : InterestCalculationRequest(
            principalAmount != null,
            principalAmount.compareTo(new BigDecimal("100")) < 0
        )
    then
        result.setInterestAmount(BigDecimal.ZERO);
        result.setInterestRate(BigDecimal.ZERO);
        result.setRateType("EXEMPT");
        result.setLegalBasis("Beloeb under 100 kr - ingen rente");
end

// No interest if not yet due
rule "No Interest Before Due Date"
    when
        $request : InterestCalculationRequest(daysPastDue <= 0)
    then
        result.setInterestAmount(BigDecimal.ZERO);
        result.setInterestRate(BigDecimal.ZERO);
        result.setRateType("NOT_DUE");
        result.setLegalBasis("Gaeld endnu ikke forfalden");
end
