{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os, runpy; runpy.run_path(os.path.join(os.environ['FACTORY_PROJECT_DIR'], '.factory', 'hooks', 'doc_sync_hook.py'), run_name='__main__')\"",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os, runpy; runpy.run_path(os.path.join(os.environ['FACTORY_PROJECT_DIR'], '.factory', 'hooks', 'doc_sync_hook.py'), run_name='__main__')\"",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os, runpy; runpy.run_path(os.path.join(os.environ['FACTORY_PROJECT_DIR'], '.factory', 'hooks', 'doc_sync_hook.py'), run_name='__main__')\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os, runpy; runpy.run_path(os.path.join(os.environ['FACTORY_PROJECT_DIR'], '.factory', 'hooks', 'doc_sync_hook.py'), run_name='__main__')\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import os, runpy; runpy.run_path(os.path.join(os.environ['FACTORY_PROJECT_DIR'], '.factory', 'hooks', 'doc_sync_hook.py'), run_name='__main__')\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
